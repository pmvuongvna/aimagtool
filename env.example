# Required for Kie AI API (server-side only)
KIE_API_KEY=your_kie_api_key_here

# Required in production for signed auth session cookie
AUTH_SESSION_SECRET=replace_with_long_random_secret

# Required in production if you call admin APIs via x-admin-token header
ADMIN_TOKEN=replace_with_strong_admin_token

# Admin credential (recommended to override in production)
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=replace_with_strong_password

# Demo auth mode: only for local development
ALLOW_DEMO_AUTH=true

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Cloudflare R2 for mirrored template thumbnails
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_BUCKET_NAME=escanor
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_PUBLIC_BASE_URL=https://images.escanor.app
